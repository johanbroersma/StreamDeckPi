{
  "name": "streamdeck-pi-agent",
  "version": "1.0.0",
  "description": "Pi Stream Deck desktop agent for macOS and Windows",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.13",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.streamdeckpi.agent",
    "productName": "StreamDeck Pi Agent",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
